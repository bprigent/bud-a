# URL of the backend API. Default points to the local Python server.
VITE_API_URL=http://localhost:8000

# Default currency code (ISO 4217) for new operations, budgets, and display.
VITE_DEFAULT_CURRENCY=EUR

# Comma-separated list of currency codes shown in dropdowns.
VITE_CURRENCIES=EUR,USD,GBP,CHF,CAD
